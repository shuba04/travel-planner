<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-page">
<nav class="navbar navbar-expand-lg">
  <div class="container-fluid">
    <span class="navbar-brand">Travel Planner Admin</span>
    <a href="/admin/logout" class="btn btn-danger">Logout</a>
  </div>
</nav>
<div class="container mt-5">
  <div class="row mb-4">
  <div class="col-md-6">
    <div class="summary-card text-center">
      <div class="summary-icon">👤</div>
      <div class="summary-label">Total Users</div>
      <div class="summary-number"><%= users.length %></div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="summary-card text-center">
      <div class="summary-icon">✈️</div>
      <div class="summary-label">Total Trips</div>
      <div class="summary-number"><%= trips.length %></div>
    </div>
  </div>
</div>

  <div class="card p-4 shadow-sm mb-5">
  <h3 class="mb-4">Registered Users</h3>

  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th class="text-center">Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td class="text-center">
              <form action="/admin/delete-user/<%= u._id %>" method="POST">
                <button class="btn btn-sm btn-danger">
                  Delete
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

  <hr>

  <div class="card p-4 shadow-sm">
  <h3 class="mb-4">All Trips</h3>

  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>User</th>
          <th>Destination</th>
          <th>Start</th>
          <th>End</th>
          <th>Budget</th>
          <th>Type</th>
          <th class="text-center">Action</th>
        </tr>
      </thead>
      <tbody>
        <% trips.forEach(t => { %>
          <tr>
            <td>
              <%= t.userId.name %><br>
              <small class="text-muted"><%= t.userId.email %></small>
            </td>
            <td><%= t.destination %></td>
            <td><%= t.startDate.toDateString() %></td>
            <td><%= t.endDate.toDateString() %></td>
            <td><%= t.budget %></td>
            <td><%= t.travelType %></td>
            <td class="text-center">
              <form action="/admin/delete-trip/<%= t._id %>" method="POST">
                <button class="btn btn-sm btn-danger">
                  Delete
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
</div>
</div>
</body>
</html>
