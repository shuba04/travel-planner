<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travel Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body class="dashboard-page">

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/trips">Travel Planner</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto align-items-center">

    <li class="nav-item me-3">
        <a class="nav-link" href="/trips/add">
            <i class="fa-solid fa-plus"></i> Add Trip
        </a>
    </li>

    <li class="nav-item dropdown">
    <a class="nav-link p-0"
       href="#"
       role="button"
       data-bs-toggle="dropdown">

        <div class="profile-circle">
            <%= user.name.charAt(0).toUpperCase() %>
        </div>

    </a>

    <ul class="dropdown-menu dropdown-menu-end p-2" style="min-width: 220px;">

    <li class="px-3 py-2">
        <div class="fw-semibold"><%= user.name %></div>
        <div class="text-muted small"><%= user.email %></div>
    </li>

    <li><hr class="dropdown-divider"></li>

    <li>
        <a class="dropdown-item text-danger" href="/logout">
            <i class="fa-solid fa-right-from-bracket me-2"></i>
            Logout
        </a>
    </li>

</ul>
</li>

</ul>
        </div>
    </div>
</nav>

<!-- MAIN CONTAINER -->
<div class="container-lg dashboard-container mt-4">


<!-- WELCOME -->
<!-- HERO SECTION -->

  <div class="dashboard-hero section-spacing">
    <h1>Explore. Plan. Travel.</h1>
    <p>Welcome back, <%= user.name %>. Your journeys start here.</p>
  </div>


<!-- SUMMARY LOGIC -->
<% 
    const today = new Date();

    const upcoming = trips.filter(t => new Date(t.startDate) > today).length;
    const ongoing = trips.filter(t => {
        const s = new Date(t.startDate);
        const e = new Date(t.endDate);
        return s <= today && today <= e;
    }).length;
    const completed = trips.filter(t => new Date(t.endDate) < today).length;
%>

<!-- SUMMARY CARDS -->
 <div class="mt-4"></div>
  <div class="row section-spacing g-4 text-center">

  <div class="col-md-3">
    <div class="summary-card">
      <div class="summary-icon">
        <i class="fa-solid fa-globe"></i>
      </div>
      <div class="summary-number"><%= trips.length %></div>
      <div class="summary-label">Total Trips</div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="summary-card">
      <div class="summary-icon">
        <i class="fa-solid fa-calendar"></i>
      </div>
      <div class="summary-number"><%= upcoming %></div>
      <div class="summary-label">Upcoming</div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="summary-card">
      <div class="summary-icon">
        <i class="fa-solid fa-plane"></i>
      </div>
      <div class="summary-number"><%= ongoing %></div>
      <div class="summary-label">Ongoing</div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="summary-card">
      <div class="summary-icon">
        <i class="fa-solid fa-check"></i>
      </div>
      <div class="summary-number"><%= completed %></div>
      <div class="summary-label">Completed</div>
    </div>
  </div>

</div>


<!-- FILTER BAR -->
<div class="mt-4">
  <div class="card p-4 shadow-sm filter-card">
    <form method="GET" action="/trips" class="row g-3">

      <div class="col-md-3">
        <input type="text" name="search" class="form-control" placeholder="Search Destination"
               value="<%= search || '' %>">
      </div>

      <div class="col-md-3">
        <select name="type" class="form-control">
          <option value="">All Types</option>
          <option value="Solo">Solo</option>
          <option value="Family">Family</option>
          <option value="Friends">Friends</option>
          <option value="Work">Work</option>
          <option value="Pilgrimage">Pilgrimage</option>
        </select>
      </div>

      <div class="col-md-2">
        <input type="date" name="from" class="form-control" value="<%= from || '' %>">
      </div>

      <div class="col-md-2">
        <input type="date" name="to" class="form-control" value="<%= to || '' %>">
      </div>

      <div class="col-md-2">
        <input type="number" name="max" class="form-control" placeholder="Max Budget"
               value="<%= max || '' %>">
      </div>

      <div class="col-12 text-center">
        <button class="btn btn-primary">
          <i class="fa-solid fa-filter me-1"></i> Apply Filters
        </button>
      </div>

    </form>
  </div>
</div>
<small style="color:gray;">
  💡 Tip: Click on a destination to view map, nearby attractions, hotels, and more.
</small>

<div class="text-end mb-3">
  <button class="btn btn-outline-primary btn-sm me-2" onclick="setGrid()">
    <i class="fa-solid fa-table-cells"></i> Grid View
  </button>
  <button class="btn btn-outline-secondary btn-sm" onclick="setList()">
    <i class="fa-solid fa-list"></i> List View
  </button>
</div>


<!-- TRIPS -->
    <div class="row g-4" id="tripContainer">


    <% trips.forEach(t => { %>
        <%
  const start = new Date(t.startDate);
  const end = new Date(t.endDate);
  const diffTime = end - start;
  const days = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
%>

        <%
            const todayLocal = new Date();
            const tripEnded = new Date(t.endDate) < todayLocal;
        %>

        <div class="col-lg-4 col-md-6">
            <div class="card mb-4 shadow-sm trip-card">
                <div class="card-body pt-3 pb-3 px-3">
                    
                    <div class="trip-title">
                      <h5 class="mb-1">
                        <a href="/trips/<%= t._id %>" class="destination-link">
                          <i class="fa-solid fa-location-dot me-2 text-primary"></i>
                          <%= t.destination %>
                        </a>
                      </h5>
                    </div>

                    <p>
                        <strong>From:</strong> <%= t.startDate.toDateString() %><br>
                        <strong>To:</strong> <%= t.endDate.toDateString() %><br>
                        <strong>Days:</strong> <%= days %><br>
                        <strong>Budget:</strong> <%= t.currency %> <%= Number(t.budget).toLocaleString("en-IN") %><br>                        

                        <%
  const remaining = Number(t.remaining);

  if (!isNaN(remaining)) {
    if (remaining >= 0) {
%>
<span class="text-success">
  Remaining: <%= t.currency %> <%= Number(remaining).toLocaleString("en-IN") %>
</span>
<%
    } else {
%>
<span class="text-danger">
  Exceeded by: <%= t.currency %> <%= Number(Math.abs(remaining)).toLocaleString("en-IN") %>
</span>

<%
    }
  } else {
%>
    <span class="text-muted">Expenses not added</span>
<%
  }
%>

                    </p>

                    <% const ended = new Date(t.endDate) < new Date(); %>

                    <% if (!ended) { %>
                        <a href="/trips/edit/<%= t._id %>" class="btn btn-warning btn-sm">Edit</a>
                        <a href="/trips/delete/<%= t._id %>" class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete trip?')">Delete</a>
                    <% } else { %>
                        <span class="text-muted">Trip Ended</span>
                    <% } %>

                    <!-- CHECKLIST BUTTON -->
                    <% if (!tripEnded) { %>
  <button class="btn btn-info btn-sm" data-bs-toggle="modal"
          data-bs-target="#checklistModal<%= t._id %>">
    Checklist
  </button>
<% } else { %>
  <button class="btn btn-secondary btn-sm" disabled>
    Checklist Locked
  </button>
<% } %>


                </div>
            </div>
        </div>

        <!-- CHECKLIST MODAL -->
        <div class="modal fade" id="checklistModal<%= t._id %>" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Checklist — <%= t.destination %></h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">



<% if (t) { %>
  <%
    const checklist = t.checklist || [];
    const totalItems = checklist.length;
    const completedItems = checklist.filter(c => c.completed).length;
    const percent = totalItems > 0
      ? Math.round((completedItems / totalItems) * 100)
      : 0;
  %>

  <div class="mb-3">
    <small><%= completedItems %> of <%= totalItems %> items completed</small>

    <div class="progress">
      <div class="progress-bar bg-success"
     role="progressbar"
     data-percent="<%= percent %>"
     aria-valuenow="<%= percent %>"
     aria-valuemin="0"
     aria-valuemax="100">
  <%= percent %>%
</div>

    </div>
  </div>
<% } %>
                                                                                                                                                                                                                                                                         

<ul class="list-group mb-3">
  <% 
    const seenItems = new Set();
    const uniqueChecklist = [];

    t.checklist.forEach(c => {
      if (!seenItems.has(c.item)) {
        seenItems.add(c.item);
        uniqueChecklist.push(c);
      }
    });
  %>

  <% if (uniqueChecklist.length === 0) { %>
    <li class="list-group-item text-muted text-center">No items yet</li>
  <% } %>

  <% uniqueChecklist.forEach(function(c, i) { %>
  <li class="list-group-item">
    <input type="checkbox"
      <%= c.completed ? "checked" : "" %>
      onchange="toggleChecklist('<%= t._id %>', <%= i %>, this)">

    <span class="<%= c.completed ? 'text-success text-decoration-line-through' : '' %>">
      <%= c.item %>
    </span>

   <button
  class="btn btn-danger btn-sm float-end delete-btn"
  data-trip-id="<%= t._id %>"
  data-index="<%= i %>">
  <i class="fa-solid fa-trash"></i>
</button>

  </li>
<% }) %>
</ul>


                        <form action="/checklist/<%= t._id %>/add" method="POST">
                            <div class="input-group">
                                <input type="text" name="item" class="form-control"
                                       placeholder="Add checklist item..." required>
                                <button class="btn btn-primary">Add</button>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>

    <% }) %>

    </div>


<!-- FOOTER -->
<footer class="text-center text-muted mt-5 mb-3">
    <small>Travel Planner © <%= new Date().getFullYear() %></small>
</footer>
<style>
  /* List view */
  .list-view .col-md-4 {
    width: 100%;
  }

  .list-view .card {
    display: flex;
    flex-direction: row;
    align-items: center;
  }

  .list-view .card-body {
    width: 100%;
  }
</style>
<script>
  function setList() {
    document.getElementById("tripContainer").classList.add("list-view");
  }

  function setGrid() {
    document.getElementById("tripContainer").classList.remove("list-view");
  }
</script>

<script>
  document.querySelectorAll('.progress-bar').forEach(bar => {
    bar.style.width = bar.dataset.percent + '%';
  });
</script>

<script>
function toggleChecklist(tripId, index, checkbox) {
  fetch(`/trips/checklist/${tripId}/toggle/${index}`)
    .then(res => res.json())
    .then(data => {
      if (data.success) {

        if (checkbox.checked) {
          checkbox.nextElementSibling.classList.add(
            "text-success",
            "text-decoration-line-through"
          );
        } else {
          checkbox.nextElementSibling.classList.remove(
            "text-success",
            "text-decoration-line-through"
          );
        }

        // ✅ UPDATE PROGRESS
        const modal = checkbox.closest(".modal-body");
        updateProgress(modal);
      }
    })
    .catch(err => {
      console.error(err);
      alert("Something went wrong");
    });
}
</script>

<script>
function deleteChecklist(tripId, index, button) {
  fetch(`/trips/checklist/${tripId}/delete/${index}`)
    .then(res => res.json())
    .then(data => {
      if (data.success) {

        const modal = button.closest(".modal-body");

        // remove item
        const li = button.closest("li");
        li.remove();

        // ✅ UPDATE PROGRESS
        updateProgress(modal);
      }
    })
    .catch(err => {
      console.error(err);
      alert("Something went wrong while deleting");
    });
}
</script>

<script>
document.addEventListener("click", function (e) {
  const btn = e.target.closest(".delete-btn");
  if (btn) {
    const tripId = btn.dataset.tripId;
    const index = btn.dataset.index;

    deleteChecklist(tripId, index, btn);
  }
});
</script>

<script>
function updateProgress(modal) {
  const checkboxes = modal.querySelectorAll("input[type='checkbox']");
  const total = checkboxes.length;
  const checked = modal.querySelectorAll("input[type='checkbox']:checked").length;

  const percent = total > 0 ? Math.round((checked / total) * 100) : 0;

  const progressBar = modal.querySelector(".progress-bar");
  const text = modal.querySelector(".mb-3 small");

  if (progressBar) {
    progressBar.style.width = percent + "%";
    progressBar.innerText = percent + "%";
  }

  if (text) {
    text.innerText = `${checked} of ${total} items completed`;
  }
}
</script>


</body>
</html>
