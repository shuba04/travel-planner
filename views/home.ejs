<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Travel Planner</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #F5F7FA;
      color: #333333;
    }
    .hero {
      background: linear-gradient(
          rgba(46, 139, 87, 0.7),
          rgba(46, 139, 87, 0.7)
        ),
        url("https://images.unsplash.com/photo-1507525428034-b723cf961d3e");
      background-size: cover;
      background-position: center;
      height: 90vh;
      display: flex;
      align-items: center;
      color: white;
    }
    .feature-icon {
      font-size: 40px;
      color: #2E8B57;
    }
  </style>
</head>

<body class="landing page">

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark" style="background:#2E8B57;">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">Travel Planner</a>
    <div>
      <a href="/login" class="btn btn-outline-light btn-sm me-2">Login</a>
      <a href="/register" class="btn btn-warning btn-sm">Sign Up</a>
    </div>
  </div>
</nav>

<!-- HERO SECTION -->
<section class="hero">
  <div class="container text-center">
    <h1 class="display-4 fw-bold">Plan Your Dream Trip</h1>
    <p class="lead mt-3">
      Discover destinations, manage budgets, build itineraries, and travel stress-free.
    </p>
    <a href="/register" class="btn btn-lg mt-4" style="background:#FFA07A; color:#000;">
      Start Planning
    </a>
  </div>
</section>

<!-- FEATURES -->
<section class="container my-5">
  <h2 class="text-center mb-4">Why Choose Travel Planner?</h2>

  <div class="row text-center">
    <div class="col-md-3">
      <div class="feature-icon">🗺</div>
      <h5 class="mt-2">Trip Planning</h5>
      <p class="text-muted">Create, edit, and manage trips easily.</p>
    </div>

    <div class="col-md-3">
      <div class="feature-icon">💰</div>
      <h5 class="mt-2">Budget Manager</h5>
      <p class="text-muted">Track expenses and stay within budget.</p>
    </div>

    <div class="col-md-3">
      <div class="feature-icon">📋</div>
      <h5 class="mt-2">Checklist</h5>
      <p class="text-muted">Never forget essentials again.</p>
    </div>

    <div class="col-md-3">
      <div class="feature-icon">📅</div>
      <h5 class="mt-2">Smart Dashboard</h5>
      <p class="text-muted">See upcoming, ongoing, and completed trips.</p>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="text-center text-muted py-4" style="background:#FFFFFF;">
  <small>
    © <%= new Date().getFullYear() %> Travel Planner |
    <a href="#" class="text-muted">Privacy</a> |
    <a href="#" class="text-muted">Terms</a>
  </small>
</footer>

</body>
</html>
